# ==========================================
# CloudGuard Environment Configurations
# ==========================================

# Active Profile for API Gateway: 'h2' (in-memory) | 'postgres' (production)
SPRING_PROFILES_ACTIVE=h2

# Database Connection (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudguard_db
DB_USER=cloudguard_user
DB_PASSWORD=cloudguard_password

# Redis Session Cache Connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka Broker Connections
KAFKA_BROKERS=localhost:9092

# Gateway Custom JWT Authentication Security
JWT_SECRET=9a4f2c8d3e5f1b7a6c0d8e4f5a3b2c1d9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f1a0b
JWT_EXPIRATION_MS=86400000

# Slack Integration Webhook
SLACK_WEBHOOK_URL=https://YOUR_SLACK_WEBHOOK_URL_HERE

# SMTP Email Alert Dispatcher settings
SMTP_USERNAME=alerts@cloudguard.io
SMTP_PASSWORD=yoursecretsmtppassword
ALERT_EMAIL_RECIPIENT=admin@cloudguard.io

# Platform Mode: 'true' uses local logs fallbacks, 'false' tries to connect real event-bus
MOCK_MODE=true
