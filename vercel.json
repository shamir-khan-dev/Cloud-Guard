{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "anomaly-detector": {
      "root": "services/anomaly-detector",
      "entrypoint": "app/main.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/anomaly-detector(/.*)?",
      "destination": {
        "type": "service",
        "service": "anomaly-detector"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
